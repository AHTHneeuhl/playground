datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String @id @default(uuid())
  email String @unique
  name  String?
  password String
}

model Project {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

model Diagram {
  id        String   @id @default(uuid())
  name      String
  projectId String
  createdAt DateTime @default(now())
}

model Node {
  id        String @id @default(uuid())
}

model Edge {
  id        String @id @default(uuid())
}